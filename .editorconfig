# https://editorconfig.org
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.md]
# Prose paragraphs are single lines; GitHub/editors wrap automatically.
# Do not hard-wrap at a column width. Keep lists, tables, and code blocks as-is.

[*.rs]
indent_style = space
indent_size = 4

[*.{ts,tsx,js,json}]
indent_style = space
indent_size = 2

[*.toml]
indent_style = space
indent_size = 2
